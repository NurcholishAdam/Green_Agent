# Ensure scripts have execute permissions when checked out
scripts/*.sh filter=lfs diff=lfs merge=lfs -text
scripts/*.sh export-ignore=false

# Specifically mark deployment scripts as executable
scripts/deploy-environment.sh text eol=lf
scripts/run-k8s-tests.sh text eol=lf
scripts/run-e2e-tests.sh text eol=lf
scripts/verify-deployment.sh text eol=lf

# K8s scripts
k8s/*.sh text eol=lf
k8s/deploy-prometheus-adapter.sh text eol=lf
